#!/bin/sh
set -eu

if ! command -v nu >/dev/null 2>&1; then
    echo "chezmoi: nu not found, skip nushell autoload generation" >&2
    exit 0
fi

autoload_dir="$(nu --no-config-file --no-newline --commands '$nu.data-dir | path join "vendor" "autoload"')"
if [ -z "$autoload_dir" ]; then
    echo "chezmoi: nushell data-dir is empty, skip nushell autoload generation" >&2
    exit 0
fi

mkdir -p "$autoload_dir"

autoload_file="$autoload_dir/chezmoi-dotfiles.nu"
tmp_file="$autoload_file.tmp.$$"
alias_cache="$autoload_dir/zz-local-aliases.nu"
trap 'rm -f "$tmp_file"' EXIT HUP INT TERM

cat >"$tmp_file" <<'NU_EOF'
# Generated by chezmoi. Do not edit.

const NUSHELL_CONFIG_DIR = ($nu.default-config-dir)
$env.NUSHELL_CONFIG_DIR = $NUSHELL_CONFIG_DIR

# Custom completions must be parsed before functions that reference them.
{{- range glob (joinPath .chezmoi.sourceDir "dot_config/nushell/completions/*.nu") }}
source ($NUSHELL_CONFIG_DIR | path join "completions" "{{ base . }}")
{{- end }}

{{- range glob (joinPath .chezmoi.sourceDir "dot_config/nushell/functions/*.nu") }}
source ($NUSHELL_CONFIG_DIR | path join "functions" "{{ base . }}")
{{- end }}

{{- range glob (joinPath .chezmoi.sourceDir "dot_config/nushell/conf.d/*.nu") }}
source ($NUSHELL_CONFIG_DIR | path join "conf.d" "{{ base . }}")
{{- end }}
NU_EOF

if [ -f "$autoload_file" ] && cmp -s "$tmp_file" "$autoload_file"; then
    exit 0
fi

mv "$tmp_file" "$autoload_file"
trap - EXIT HUP INT TERM

if [ ! -e "$alias_cache" ]; then
    cat >"$alias_cache" <<'NU_EOF'
# Auto-generated by shells-regen-aliases. Do not edit.
# Placeholder; conf.d/45-local-aliases.nu regenerates this file from ~/.aliases.
NU_EOF
    touch -t 197001010000 "$alias_cache" 2>/dev/null || :
fi
