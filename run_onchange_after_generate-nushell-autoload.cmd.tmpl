@echo off
setlocal EnableExtensions DisableDelayedExpansion

where nu >nul 2>nul
if errorlevel 1 (
    echo chezmoi: nu not found, skip nushell autoload generation 1>&2
    exit /b 0
)

set "wrote_autoload="

if defined APPDATA (
    call :write_autoload "%APPDATA%\nushell\vendor\autoload"
    if errorlevel 1 exit /b 1
)

set "nu_data_dir="
for /f "usebackq delims=" %%A in (`nu --no-config-file --no-newline --commands "$nu.data-dir" 2^>nul`) do set "nu_data_dir=%%A"
if defined nu_data_dir (
    call :write_autoload "%nu_data_dir%\vendor\autoload"
    if errorlevel 1 exit /b 1
)

if not defined wrote_autoload (
    echo chezmoi: nushell data-dir is empty, skip nushell autoload generation 1>&2
    exit /b 0
)

exit /b 0

:write_autoload
set "autoload_dir=%~1"
if not defined autoload_dir exit /b 0
set "wrote_autoload=1"

if not exist "%autoload_dir%" mkdir "%autoload_dir%" >nul 2>nul
if errorlevel 1 (
    echo chezmoi: failed to create nushell autoload directory: %autoload_dir% 1>&2
    exit /b 1
)

set "autoload_file=%autoload_dir%\chezmoi-dotfiles.nu"
set "tmp_file=%autoload_file%.tmp.%RANDOM%%RANDOM%"
set "alias_cache=%autoload_dir%\zz-local-aliases.nu"

> "%tmp_file%" echo # Generated by chezmoi. Do not edit.
>> "%tmp_file%" echo.
>> "%tmp_file%" echo const NUSHELL_CONFIG_DIR = ^($nu.default-config-dir^)
>> "%tmp_file%" echo $env.NUSHELL_CONFIG_DIR = $NUSHELL_CONFIG_DIR
>> "%tmp_file%" echo.
>> "%tmp_file%" echo # Custom completions must be parsed before functions that reference them.
{{- range glob (joinPath .chezmoi.sourceDir "dot_config/nushell/completions/*.nu") }}
>> "%tmp_file%" echo source ^($NUSHELL_CONFIG_DIR ^| path join "completions" "{{ base . }}"^)
{{- end }}
>> "%tmp_file%" echo.
{{- range glob (joinPath .chezmoi.sourceDir "dot_config/nushell/functions/*.nu") }}
>> "%tmp_file%" echo source ^($NUSHELL_CONFIG_DIR ^| path join "functions" "{{ base . }}"^)
{{- end }}
>> "%tmp_file%" echo.
{{- range glob (joinPath .chezmoi.sourceDir "dot_config/nushell/conf.d/*.nu") }}
>> "%tmp_file%" echo source ^($NUSHELL_CONFIG_DIR ^| path join "conf.d" "{{ base . }}"^)
{{- end }}

if exist "%autoload_file%" (
    fc /b "%tmp_file%" "%autoload_file%" >nul 2>nul
    if not errorlevel 1 (
        del /q "%tmp_file%" >nul 2>nul
        exit /b 0
    )
)

move /y "%tmp_file%" "%autoload_file%" >nul
if errorlevel 1 (
    del /q "%tmp_file%" >nul 2>nul
    exit /b 1
)

if exist "%alias_cache%" exit /b 0

> "%alias_cache%" echo # Auto-generated by shells-regen-aliases. Do not edit.
>> "%alias_cache%" echo # Placeholder; conf.d/45-local-aliases.nu regenerates this file from ~/.aliases.
powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "try { (Get-Item -LiteralPath $env:alias_cache).LastWriteTime = [datetime]'1970-01-01T00:00:00' } catch { exit 0 }" >nul 2>nul
exit /b 0
