# Xonsh shell configuration file.
# Managed by chezmoi, corresponds to ~/.xonshrc.

import sys
from pathlib import Path

if sys.stdin.isatty():
    _xonsh_config_file = Path.home() / ".config" / "xonsh" / "config.xsh"
    if _xonsh_config_file.is_file():
        source @(str(_xonsh_config_file))
    del _xonsh_config_file
